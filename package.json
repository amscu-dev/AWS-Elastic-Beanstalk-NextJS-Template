{
  "name": "aws_elastic_beanstalk_nextjs_cicd",
  "version": "0.0.4",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "prod": "next build --webpack && next start",
    "lint": "eslint . ",
    "lint:fix": "eslint . --fix ",
    "lint:ci": "eslint . --max-warnings=0 ",
    "lint:md": "markdownlint --config .github/linters/.markdownlint.yaml --ignore-path .markdownlintignore \"**/*.md\"",
    "lint:md:fix": "markdownlint --config .github/linters/.markdownlint.yaml --fix --ignore-path .markdownlintignore \"**/*.md\"",
    "format:fix": "prettier --write .",
    "format:check": "prettier --check .",
    "format:sh": "prettier --write ./scripts/*.sh",
    "test:e2e": "npx playwright test --workers=4",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:headed": "npx playwright test --headed",
    "test:e2e:debug": "npx playwright test --debug",
    "test:e2e:report": "npx playwright show-report",
    "test:e2e:codegen": "npx playwright codegen http://localhost:3000",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "typecheck": "tsc",
    "lint-staged": "lint-staged",
    "commit": "cz",
    "knip": "knip --max-show-issues 5 --config knip.json --cache",
    "knip:prod": "knip --max-show-issues 5 --config knip.json --cache --production",
    "knip:clean": "knip --fix --allow-remove-files",
    "version": "npx changeset",
    "check:merge-conflicts": "bash ./scripts/check-merge-conflicts.sh",
    "cspell": "cspell --no-must-find-files --gitignore --unique .",
    "gitleaks": "bash ./scripts/gitleaks.sh all",
    "gitleaks:staged": "bash ./scripts/gitleaks.sh staged",
    "actionlint": "bash ./scripts/actionlint.sh all",
    "actionlint:staged": "bash ./scripts/actionlint.sh staged",
    "zizmor:online": "bash ./scripts/zizmor.sh online",
    "zizmor:offline": "bash ./scripts/zizmor.sh offline",
    "zizmor:staged": "bash ./scripts/zizmor.sh staged"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.md": [
      "prettier --write",
      "markdownlint --config .github/linters/.markdownlint.yaml --ignore-path .markdownlintignore --fix"
    ],
    "*.{yaml,yml}": [
      "prettier --write"
    ],
    "*.json": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.sh": [
      "prettier --write"
    ]
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "overrides": {
    "lodash": "4.18.1",
    "commitizen": {
      "inquirer": {
        "external-editor": {
          "tmp": "0.2.5"
        }
      }
    },
    "@vercel/config": {
      "@vercel/routing-utils": {
        "path-to-regexp": "6.3.0"
      }
    }
  },
  "dependencies": {
    "@changesets/cli": "^2.30.0",
    "@reduxjs/toolkit": "^2.11.2",
    "@t3-oss/env-nextjs": "^0.13.11",
    "@tanstack/react-query": "^5.96.2",
    "@tanstack/react-query-devtools": "^5.96.2",
    "@uidotdev/usehooks": "^2.4.1",
    "axios": "1.15.0",
    "fast-memoize": "^2.5.2",
    "flagsmith-nodejs": "^8.0.2",
    "next": "16.2.2",
    "nuqs": "^2.8.9",
    "proxy-memoize": "^3.0.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-error-boundary": "^6.1.1",
    "react-redux": "^9.2.0",
    "serialize-javascript": "^7.0.5",
    "server-only": "^0.0.1",
    "superjson": "^2.2.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vercel/config": "^0.1.1",
    "commitizen": "^4.3.1",
    "cspell": "^10.0.0",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-json": "^4.0.1",
    "eslint-plugin-jsonc": "^3.1.2",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jest-fixed-jsdom": "^0.0.11",
    "knip": "^6.4.1",
    "lint-staged": "^16.4.0",
    "markdownlint-cli": "^0.48.0",
    "msw": "^2.13.2",
    "prettier": "^3.8.2",
    "prettier-plugin-sh": "^0.18.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  }
}
